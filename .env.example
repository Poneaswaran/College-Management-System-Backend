# Copy this file to .env and replace placeholder values.

AI_SERVICE_BASE_URL=http://127.0.0.1:8001
AI_SERVICE_API_SECRET=replace-with-strong-secret
AI_SERVICE_SOURCE_HEADER=django-cms-backend

AI_SERVICE_INGEST_PATH=/ingest
AI_SERVICE_QUERY_PATH=/query
AI_SERVICE_DELETE_PATH=/delete

AI_SERVICE_CONNECT_TIMEOUT_SECONDS=5
# Set 0 to disable read timeout (wait indefinitely for AI response)
AI_SERVICE_TIMEOUT_SECONDS=0

AI_INGEST_MAX_RETRIES=3
AI_INGEST_BACKOFF_SECONDS=2

AI_CHAT_MAX_MESSAGE_LENGTH=1000
AI_CHAT_THROTTLE_RATE=20/hour
